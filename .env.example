###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=change_me_with_a_random_32_char_string
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> symfony/routing ###
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> doctrine/doctrine-bundle ###
# SQLite (défaut — aucune installation requise)
DATABASE_URL="sqlite:///%kernel.project_dir%/var/jobscan.db"

# PostgreSQL (optionnel)
# DATABASE_URL="postgresql://user:password@127.0.0.1:5432/jobscan?serverVersion=16&charset=utf8"

# MySQL / MariaDB (optionnel)
# DATABASE_URL="mysql://user:password@127.0.0.1:3306/jobscan?serverVersion=8.0.32&charset=utf8mb4"
###< doctrine/doctrine-bundle ###

###> searxng ###
# Instance SearXNG locale (Docker recommandé)
# docker run -d -p 8080:8080 searxng/searxng
SEARXNG_URL=http://localhost:8080
###< searxng ###

###> lm-studio ###
# Endpoint LM Studio (API compatible OpenAI)
# Démarrer LM Studio → charger un modèle → activer le serveur local
AI_API_BASE=http://localhost:1234/v1
AI_API_KEY=lmstudio

# Modèle à utiliser (laisser commenté pour utiliser le modèle actif dans LM Studio)
# AI_MODEL=google/gemma-3-4b-it
# AI_MODEL=mistralai/mistral-7b-instruct
###< lm-studio ###

###> telegram ###
# Créer un bot via @BotFather sur Telegram
TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Récupérer l'ID de votre chat via @userinfobot ou l'API Telegram
TELEGRAM_CHAT_ID=123456789
###< telegram ###

###> rss-feeds ###
# Flux RSS d'offres d'emploi — ajouter autant que nécessaire
JOB_FEED_URL_1=https://remoteok.com/remote-dev-jobs.rss
JOB_FEED_URL_2=https://www.reddit.com/r/forhire/.rss
# JOB_FEED_URL_3=https://weworkremotely.com/categories/remote-programming-jobs.rss
###< rss-feeds ###